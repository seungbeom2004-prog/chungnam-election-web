generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Candidate {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  district        String
  profileImage    String?
  slogan          String?
  bio             String?
  phone           String?
  electionType          String?
  detailedElectionName  String?
  province        String?
  electionId      String?
  candidateStatus String?
  isNominated     Boolean?
  isNecRegistered Boolean?
  party           String   @default("개혁")
  role            String   @default("candidate")
  verified        Boolean  @default(false)
  pinLat          Float?
  pinLng          Float?
  youtube         String?
  instagram       String?
  twitter         String?
  facebook        String?
  tiktok          String?
  kakao           String?
  naverBlog       String?
  articleUrl      String?
  articleTitle    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pledges         Pledge[]

  @@index([district])
  @@index([verified])
}

model Pledge {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  budget      String?
  imageUrl    String?
  youtubeUrl  String?
  latitude    Float
  longitude   Float
  address     String?
  visible     Boolean   @default(true)
  pledgeType  String    @default("map")
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  likes         PledgeLike[]
  comments      PledgeComment[]

  @@index([candidateId])
  @@index([visible])
  @@index([pledgeType])
}

model District {
  id        String @id @default(cuid())
  name      String
  code      String @unique
  centerLat Float
  centerLng Float
}

model ProposalPost {
  id           String   @id @default(cuid())
  title        String   @default("")
  content      String   @db.Text
  authorName   String
  passwordHash String?
  city         String?
  candidateId  String?
  ipHash       String
  status       String   @default("pending")
  latitude     Float?
  longitude    Float?
  acceptedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())

  likes       ProposalLike[]

  @@index([candidateId])
  @@index([city])
  @@index([status])
  @@index([ipHash])
  @@index([createdAt])
}

model ProposalLike {
  id         String   @id @default(cuid())
  proposalId String
  proposal   ProposalPost @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  ipHash     String
  createdAt  DateTime @default(now())

  @@unique([proposalId, ipHash])
  @@index([proposalId])
}

model CandidateLike {
  id          String   @id @default(cuid())
  candidateId String
  ipHash      String
  createdAt   DateTime @default(now())

  @@unique([candidateId, ipHash])
  @@index([candidateId])
}

model PledgeLike {
  id        String   @id @default(cuid())
  pledgeId  String
  pledge    Pledge   @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  ipHash    String
  createdAt DateTime @default(now())

  @@unique([pledgeId, ipHash])
  @@index([pledgeId])
}

model PledgeComment {
  id           String    @id @default(cuid())
  pledgeId     String
  pledge       Pledge    @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  content      String    @db.Text
  authorName   String
  passwordHash String
  ipHash       String
  status       String    @default("visible")
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([pledgeId])
  @@index([status])
}
