generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Candidate {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  district        String
  profileImage    String?
  slogan          String?
  bio             String?
  phone           String?
  electionType          String?
  detailedElectionName  String?
  province        String?
  electionId      String?
  candidateStatus String?
  isNominated     Boolean?
  isNecRegistered Boolean?
  party           String   @default("개혁")
  role            String   @default("candidate")
  verified        Boolean  @default(false)
  pinLat          Float?
  pinLng          Float?
  youtube         String?
  instagram       String?
  twitter         String?
  facebook        String?
  tiktok          String?
  kakao           String?
  naverBlog       String?
  donationUrl     String?
  contactEmail    String?
  showPhone       Boolean  @default(false)
  showContactEmail Boolean @default(false)
  articleUrl      String?
  articleTitle    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pledges         Pledge[]

  @@index([district])
  @@index([verified])
}

model Pledge {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  budget      String?
  imageUrl    String?
  youtubeUrl  String?
  latitude    Float
  longitude   Float
  address     String?
  visible        Boolean   @default(true)
  pledgeType     String    @default("map")
  background     String?   @db.Text  // 배경/필요성
  plan           String?   @db.Text  // 실행 방안
  expectedEffect String?   @db.Text  // 기대 효과
  relatedLinks   Json?               // 관련 링크 JSON 배열 [{url, title, type}]
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  likes            PledgeLike[]
  comments         PledgeComment[]
  linkedMinwons    PledgeToMinwon[]
  linkedProposals  PledgeToProposal[]

  @@index([candidateId])
  @@index([visible])
  @@index([pledgeType])
}

/// 공약 제안 (middle layer between 민원 and 정식 공약)
/// authorType: "visitor" | "candidate"
model PledgeProposal {
  id           String   @id @default(cuid())
  title        String
  content      String   @db.Text
  authorName   String
  authorType   String   @default("visitor") // "visitor" | "candidate"
  candidateId  String?  // set when authorType == "candidate"
  ipHash       String?  // set when authorType == "visitor"
  passwordHash String?  // visitor password for self-deletion
  status       String   @default("pending") // "pending" | "accepted" | "deleted"
  createdAt    DateTime @default(now())

  minwonLinks  PledgeProposalMinwon[]
  pledgeLinks  PledgeToProposal[]

  @@index([candidateId])
  @@index([status])
  @@index([createdAt])
}

/// 공약 제안 ↔ 민원 (다대다, 재사용 가능)
model PledgeProposalMinwon {
  id               String         @id @default(cuid())
  pledgeProposalId String
  pledgeProposal   PledgeProposal @relation(fields: [pledgeProposalId], references: [id], onDelete: Cascade)
  minwonId         String         // ProposalPost.id where postType = "민원"
  createdAt        DateTime       @default(now())

  @@unique([pledgeProposalId, minwonId])
  @@index([minwonId])
}

/// 정식 공약 ↔ 민원 (일대일 — 민원 1개는 공약 1개에만 연결 가능)
model PledgeToMinwon {
  id        String   @id @default(cuid())
  pledgeId  String
  pledge    Pledge   @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  minwonId  String   @unique  // 민원 1개 → 공약 최대 1개
  createdAt DateTime @default(now())

  @@index([pledgeId])
}

/// 정식 공약 ↔ 공약 제안 (일대일 — 공약 제안 1개는 공약 1개에만 연결 가능)
model PledgeToProposal {
  id               String         @id @default(cuid())
  pledgeId         String
  pledge           Pledge         @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  pledgeProposalId String         @unique  // 공약 제안 1개 → 공약 최대 1개
  pledgeProposal   PledgeProposal @relation(fields: [pledgeProposalId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@index([pledgeId])
}

model District {
  id        String @id @default(cuid())
  name      String
  code      String @unique
  centerLat Float
  centerLng Float
}

model ProposalPost {
  id           String   @id @default(cuid())
  title        String   @default("")
  content      String   @db.Text
  authorName   String
  passwordHash String?
  city         String?
  /// 법정동 이름 (예: 봉명동) — 좌표→reverse geocode 결과 저장
  legalDong    String?
  /// 행정동 이름 (예: 봉명1동)
  admDong      String?
  candidateId  String?
  ipHash       String
  status       String   @default("pending")
  latitude     Float?
  longitude    Float?
  postType     String   @default("제안")
  acceptedAt   DateTime?
  deletedAt    DateTime?
  createdAt    DateTime @default(now())

  likes       ProposalLike[]
  responses   ProposalResponse[]

  @@index([candidateId])
  @@index([city])
  @@index([status])
  @@index([ipHash])
  @@index([createdAt])
}

model ProposalLike {
  id         String   @id @default(cuid())
  proposalId String
  proposal   ProposalPost @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  ipHash     String
  createdAt  DateTime @default(now())

  @@unique([proposalId, ipHash])
  @@index([proposalId])
}

/// 후보자가 제보/제안 게시물에 남기는 공식 답변 (단계별 N개 가능)
/// (proposalId, candidateId, status) 조합으로 unique — 같은 후보자가 단계마다 1개 답변
model ProposalResponse {
  id                    String   @id @default(cuid())
  proposalId            String
  proposal              ProposalPost @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  candidateId           String
  candidateName         String
  candidateProfileImage String?
  /// "접수됨" | "검토 중" | "민원 접수" | "민원 해결" | "민원 실패"
  /// "공약 반영 예정" | "공약 반영 완료" | "반영 불가"
  status                String   @default("접수됨")
  content               String   @db.Text
  /// 관공서 공식 답변 첨부 (민원 해결/실패 시)
  officialResponse      String?  @db.Text
  /// 공약 반영 완료 또는 정식 공약 연결 시 해당 공약 ID
  pledgeId              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([proposalId, candidateId, status])
  @@index([proposalId])
  @@index([candidateId])
}

/// QR 코드 추적 — 사이트 내부 경로에 대해 여러 별명을 만들고 유입 카운트
model QrCode {
  id          String    @id @default(cuid())
  code        String    @unique        // short slug
  name        String                   // label ("현수막", "전단지" 등)
  targetPath  String                   // internal path
  ownerType   String    @default("admin") // "admin" | "candidate"
  ownerId     String?                  // candidate id (null for admin)
  hitCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hits        QrHit[]

  @@index([ownerId])
  @@index([ownerType])
  @@index([code])
}

model QrHit {
  id          BigInt    @id @default(autoincrement())
  qrId        String
  qr          QrCode    @relation(fields: [qrId], references: [id], onDelete: Cascade)
  ipHash      String?
  userAgent   String?
  referrer    String?
  createdAt   DateTime  @default(now())

  @@index([qrId])
  @@index([createdAt])
}

model CandidateLike {
  id          String   @id @default(cuid())
  candidateId String
  ipHash      String
  createdAt   DateTime @default(now())

  @@unique([candidateId, ipHash])
  @@index([candidateId])
}

model PledgeLike {
  id        String   @id @default(cuid())
  pledgeId  String
  pledge    Pledge   @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  ipHash    String
  createdAt DateTime @default(now())

  @@unique([pledgeId, ipHash])
  @@index([pledgeId])
}

model PledgeComment {
  id           String    @id @default(cuid())
  pledgeId     String
  pledge       Pledge    @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  content      String    @db.Text
  authorName   String
  passwordHash String
  ipHash       String
  status       String    @default("visible")
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([pledgeId])
  @@index([status])
}
